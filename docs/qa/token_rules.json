{
    "body-candles.html": [
        {
            "selector": ".bc-section-title",
            "property": "font-size",
            "token": "--text-h1",
            "description": "Body candles section heading should use h1 token size."
        },
        {
            "selector": ".bc-section-copy",
            "property": "font-size",
            "token": "--text-body-large",
            "description": "Body candles section copy should use body-large token size."
        },
        {
            "selector": ".bc-feature-scar-copy h2",
            "property": "font-size",
            "token": "--text-h1",
            "description": "Scar collection heading should use h1 token size."
        }
    ],
    "scar-collection.html": [
        {
            "selector": ".scar-collection-page .small-hero h1",
            "property": "font-size",
            "token": "--text-h1",
            "description": "Scar collection hero heading should use h1 token size.",
            "widths": [
                1920,
                768
            ]
        },
        {
            "selector": ".scar-collection-page .small-hero p",
            "property": "color",
            "token": "--text-primary",
            "description": "Scar collection hero copy should use primary text token.",
            "widths": [
                1920,
                768
            ]
        },
        {
            "selector": ".scar-collection-page .sort-label",
