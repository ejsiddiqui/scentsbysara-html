        {
            "selector": ".scar-collection-page .commitment-item p",
            "property": "color",
            "token": "--color-slate",
            "description": "Commitment body copy should use slate token color."
        },
        {
            "selector": ".scar-collection-page .small-hero h1",
            "property": "font-size",
            "token": "--text-body-large",
            "widths": [
                375
            ],
            "description": "Mobile hero heading uses body-large token at \u2264480px."
        },
        {
            "selector": ".scar-collection-page .small-hero p",
            "property": "color",
            "token": "--color-mocha",
            "widths": [
                375
            ],
            "description": "Mobile hero copy uses slate token at \u2264480px."
        }
    ],
